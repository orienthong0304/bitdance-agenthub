{
  "name": "bytedance-agenthub",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "sqlite:ensure:node": "node scripts/ensure-node-sqlite.mjs",
    "sqlite:ensure:electron": "node scripts/ensure-electron-sqlite.mjs",
    "dev": "pnpm sqlite:ensure:node && node node_modules/next/dist/bin/next dev",
    "build": "pnpm sqlite:ensure:electron && node scripts/run-electron-node.mjs node_modules/next/dist/bin/next build",
    "start": "pnpm sqlite:ensure:electron && node scripts/run-electron-node.mjs node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "test": "pnpm sqlite:ensure:node && vitest run",
    "test:watch": "pnpm sqlite:ensure:node && vitest",
    "e2e": "pnpm sqlite:ensure:node && playwright test",
    "e2e:ui": "pnpm sqlite:ensure:node && playwright test --ui",
    "typecheck": "tsc --noEmit",
    "db:generate": "pnpm sqlite:ensure:electron && node scripts/run-electron-node.mjs node_modules/drizzle-kit/bin.cjs generate",
    "db:push": "pnpm sqlite:ensure:electron && node scripts/run-electron-node.mjs node_modules/drizzle-kit/bin.cjs push --force",
    "db:studio": "pnpm sqlite:ensure:electron && node scripts/run-electron-node.mjs node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "pnpm sqlite:ensure:electron && node scripts/run-electron-node.mjs node_modules/tsx/dist/cli.mjs src/db/seed.ts",
    "electron:tsc": "tsc -p electron/tsconfig.json",
    "electron:tsc:watch": "tsc -w -p electron/tsconfig.json --preserveWatchOutput",
    "electron:rebuild": "node scripts/rebuild-electron-sqlite.mjs",
    "electron:prebuild": "node scripts/electron-prebuild.mjs",
    "electron:dev": "concurrently -k -n NEXT,TSC,ELECTRON -c blue,yellow,magenta \"pnpm dev\" \"pnpm electron:tsc:watch\" \"wait-on -d 200 tcp:127.0.0.1:3000 file:./dist-electron/main.js && node scripts/electron-dev.mjs\"",
    "electron:build": "pnpm build && pnpm electron:prebuild && pnpm electron:tsc && electron-builder",
    "mobile:dev": "pnpm --filter @agenthub/mobile dev",
    "mobile:build": "pnpm --filter @agenthub/mobile build",
    "mobile:sync": "pnpm --filter @agenthub/mobile cap:sync",
    "mobile:open:ios": "pnpm --filter @agenthub/mobile cap:open:ios",
    "mobile:open:android": "pnpm --filter @agenthub/mobile cap:open:android"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.197",
    "@anthropic-ai/sdk": "^0.98.0",
    "@base-ui/react": "^1.5.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "0.136.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "immer": "^11.1.8",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "openai": "^6.39.0",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.4",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.8.0",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.agenthub.app",
    "productName": "AgentHub",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**"
    ],
    "files": [
      "dist-electron/**",
      ".next/standalone/**",
      "!.next/standalone/release/**",
      "!.next/standalone/.agenthub-data/**",
      "!.next/standalone/apps/**",
      "package.json"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ]
  }
}
